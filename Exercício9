function compactarTexto(texto) {
if (texto === "") {
return "";
}

let resultado = "";
let contador = 1;

for (let i = 0; i < texto.length; i++) {
let letraAtual = texto[i];
let proximaLetra = texto[i + 1];

if (letraAtual === proximaLetra) {
  contador++;
} else {
  resultado = resultado + letraAtual + contador;
  
  contador = 1; 
}
}

return resultado;
}
